---
const donateUrl = 'https://mpactministries.networkforgood.com/projects/140645-giving-page';
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3">
      <img src="/images/logo.webp" alt="MPACT Ministries logo representing total faith in Christ and a men's ministry in Melbourne Fl" class="h-12 w-auto" />
    </a>
    <nav class="flex items-center gap-3 sm:gap-4">
      <a href="#brotherhood" class="hidden sm:inline-flex items-center px-4 py-2 rounded-md font-semibold text-white bg-[var(--color-brand-red)] hover:opacity-90 transition">Join The Brotherhood</a>
      <a href={donateUrl} target="_blank" rel="noopener" class="inline-flex items-center px-4 py-2 rounded-md font-semibold text-white bg-[var(--color-brand-green)] hover:opacity-90 transition">Support The Mission</a>
    </nav>
  </div>
</header>
