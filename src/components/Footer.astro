---
const email = 'mpactmen@mpactministries.org';
---
<footer class="bg-gray-900 text-gray-200 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <img src="https://pbrlhyansxjdndccwtau.supabase.co/storage/v1/object/public/media-public/e669c67e-2f4b-4bd5-9546-79fb77d9a824/root/1778086613893_logo.webp" alt="MPACT Ministries logo representing total faith in Christ and a men's ministry in Melbourne Fl" class="h-16 w-auto bg-white rounded-md p-2" />
    </div>
    <div>
      <h3 class="font-display font-semibold text-white mb-3">Contact Us</h3>
      <a href={`mailto:${email}`} class="hover:text-white underline">{email}</a>
    </div>
    <div>
      <h3 class="font-display font-semibold text-white mb-3">Follow</h3>
      <div class="flex items-center gap-3">
        <a href="https://www.facebook.com/mpactformen/" target="_blank" rel="noopener" aria-label="Facebook">
          <img src="/images/facebook-square.svg" alt="social media icon" class="h-8 w-8" />
        </a>
        <a href="https://www.instagram.com/mpactministry/" target="_blank" rel="noopener" aria-label="Instagram">
          <img src="/images/instagram-square.svg" alt="social media icon" class="h-8 w-8" />
        </a>
        <a href="https://www.youtube.com/@mpactministry" target="_blank" rel="noopener" aria-label="YouTube">
          <img src="/images/youtube-square.svg" alt="social media icon" class="h-8 w-8" />
        </a>
      </div>
      <h3 class="font-display font-semibold text-white mt-6 mb-3">Cussin' Christians</h3>
      <div class="flex items-center gap-3">
        <a href="https://www.facebook.com/Cussinchristians" target="_blank" rel="noopener" aria-label="Facebook">
          <img src="/images/facebook-square.svg" alt="social media icon" class="h-8 w-8" />
        </a>
        <a href="https://www.instagram.com/cussinchristianpodcast/" target="_blank" rel="noopener" aria-label="Instagram">
          <img src="/images/instagram-square.svg" alt="social media icon" class="h-8 w-8" />
        </a>
      </div>
    </div>
  </div>
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-sm text-gray-400 text-center">
      Powered by HyppoAds
    </div>
  </div>
</footer>
