---
const email = 'mpactmen@mpactministries.org';
---
<section id="contact" class="py-20 bg-[var(--color-brand-red)] text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display font-bold text-4xl sm:text-5xl">Contact Us</h2>
    <a href={`mailto:${email}`} class="mt-6 inline-block text-xl sm:text-2xl underline hover:opacity-90">{email}</a>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://www.facebook.com/mpactformen/" target="_blank" rel="noopener" class="inline-flex justify-center items-center px-6 py-3 rounded-md font-semibold text-[var(--color-brand-red)] bg-white hover:opacity-90 transition">Facebook</a>
      <a href="https://www.instagram.com/mpactministry/" target="_blank" rel="noopener" class="inline-flex justify-center items-center px-6 py-3 rounded-md font-semibold text-[var(--color-brand-red)] bg-white hover:opacity-90 transition">Instagram</a>
      <a href="https://www.youtube.com/@mpactministry" target="_blank" rel="noopener" class="inline-flex justify-center items-center px-6 py-3 rounded-md font-semibold text-[var(--color-brand-red)] bg-white hover:opacity-90 transition">YouTube</a>
    </div>
  </div>
</section>
